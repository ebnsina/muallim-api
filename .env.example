# Copy to .env and adjust. Never commit .env.

# development | staging | production
LMS_ENV=development
LMS_VERSION=dev

LMS_ADDR=:8080
LMS_READ_TIMEOUT=10s
LMS_WRITE_TIMEOUT=30s
LMS_IDLE_TIMEOUT=120s
LMS_SHUTDOWN_TIMEOUT=20s

# Required to serve requests. `-dump-spec` does not need it.
#
# The role must NOT be a superuser: superusers bypass row-level security, which
# would silently disable tenant isolation.
LMS_DATABASE_URL=postgres://lms:lms@localhost:5432/lms?sslmode=disable

# Used only by `make test-db`.
LMS_TEST_DATABASE_URL=postgres://lms:lms@localhost:5432/lms_test?sslmode=disable

# Pool sizing. Small on purpose: Postgres costs roughly 10 MB per connection and
# degrades past a few hundred, so a small pool with a queue beats a large one.
LMS_DB_MAX_CONNS=10
LMS_DB_MIN_CONNS=2

# A query still running after this long is a bug or a missing index. Postgres
# cancels it rather than let it block every other request.
LMS_DB_STATEMENT_TIMEOUT=5s

# Queries slower than this are logged at warn, with their statement text.
LMS_DB_SLOW_QUERY_THRESHOLD=200ms

# How long a host-to-tenant resolution may be stale. It also bounds how long a
# suspended tenant keeps serving, so it is minutes, not hours. 0 disables caching.
LMS_TENANT_CACHE_TTL=5m

# Signs access tokens. At least 32 bytes; the process refuses a shorter one.
# Required outside development, where an ephemeral key is generated per boot.
#   openssl rand -base64 48
LMS_JWT_SECRET=
LMS_JWT_ISSUER=muallim-api

# Credential endpoints are throttled per client address per path. Each Argon2id
# verification allocates 64 MiB, so an unlimited login endpoint is a
# memory-exhaustion primitive. Burst attempts, then one every LMS_AUTH_RATE_EVERY.
LMS_AUTH_RATE_BURST=10
LMS_AUTH_RATE_EVERY=6s

# Comma-separated browser origins allowed to call this API directly.
#
# muallim-web needs none of them: the edge serves it at acme.muallim.com and routes
# acme.muallim.com/api/* here, so its requests are same-origin. This exists for a
# client that does call the API cross-origin from a browser. Leave it unset and
# no browser on another origin can reach this API at all, which is the right
# default. "*" is rejected: the API allows credentials, and browsers refuse a
# wildcard alongside them.
LMS_CORS_ORIGINS=

# The origin of the web client. Every link this system mails — verify an address,
# reset a password, accept an invitation — points at a page there, not at this
# API. It must be absolute.
LMS_WEB_BASE_URL=http://localhost:5173

# SMTP delivery, used by `cmd/worker`. With no host set, the worker logs messages
# instead of sending them — which prints single-use tokens into the log, so the
# process refuses to start that way outside development.
LMS_SMTP_HOST=
LMS_SMTP_PORT=587
LMS_SMTP_USERNAME=
LMS_SMTP_PASSWORD=
LMS_MAIL_FROM=LMS <no-reply@localhost>

# Appends every message to a file, one JSON object per line, instead of sending
# it. An end-to-end test reads the link a message carries; there is no other way
# to accept an invitation without standing up an SMTP server. It writes
# single-use credentials to disk in plaintext, so the process refuses it outside
# development.
LMS_MAIL_FILE=

# Video. A lesson's `video_url` is what an author typed; the player URL that ends
# up in an `iframe` is written by a provider here, from a video id, on a host it
# recognises. YouTube and Vimeo need no configuration at all.
#
# The Cloudflare Stream customer code — the label in
# `customer-<code>.cloudflarestream.com`, on the Stream dashboard. Empty means
# this deployment hosts no video, and the `hosted` source is refused.
LMS_CLOUDFLARE_STREAM_CUSTOMER=

# Hosts whose pages an author may frame with the `embed` source, comma-separated.
# This is the one source where the framed URL is an author's own, so it is off
# until you name the hosts you trust. Anyone holding `course:write` can point it
# anywhere on this list, at every reader of the lesson.
LMS_EMBED_ALLOWED_HOSTS=

# The object store, where learners' uploaded assignments live.
#
# Cloudflare R2 in production; MinIO in a container for development. They speak
# the same protocol, so there is one implementation — a development store that
# behaves differently from the production one hides the bug you are about to ship.
#
# All four must be set together or not at all. Unset means this deployment cannot
# accept an upload, and says so when somebody tries. `make storage-up` starts a
# local MinIO and creates the bucket.
LMS_S3_ENDPOINT=http://localhost:9002
LMS_S3_BUCKET=lms-uploads
LMS_S3_ACCESS_KEY=lms
LMS_S3_SECRET_KEY=lms-secret-key

# R2 ignores the region but SigV4 signs it, so it has to match on both sides.
LMS_S3_REGION=auto

# Address a bucket as `endpoint/bucket/key` rather than `bucket.endpoint/key`.
# MinIO needs it; R2 accepts it.
LMS_S3_PATH_STYLE=true

# How many jobs the worker runs at once.
LMS_WORKER_MAX_WORKERS=10

# debug | info | warn | error
LMS_LOG_LEVEL=info
